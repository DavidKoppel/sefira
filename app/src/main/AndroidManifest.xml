                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!--
            stopWithTask="false": service keeps running when the app is swiped away.
            It stops itself automatically after Shavuot.
        -->
        <!--
            foregroundServiceType="shortService" satisfies Android 14's requirement
            that every foreground service declare a type (targetSdk >= 34).
            The service runs briefly to schedule the alarm, then stops itself.
        -->
