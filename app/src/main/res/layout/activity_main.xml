<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/gold"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="ספירת העומר"
            android:textSize="20sp"
            android:textColor="@color/gold_light"
            android:fontFamily="serif" />

        <!-- Enable switch -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchEnabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Enable Reminder"
            android:textColor="@color/text_light"
            android:textSize="18sp" />

        <!-- Tonight's omer info -->
        <TextView
            android:id="@+id/tvOmerInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:textColor="@color/gold"
            android:textSize="16sp"
            android:textStyle="italic"
            android:gravity="center"
            android:fontFamily="serif"
            android:visibility="gone" />

        <!-- Status card -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:textColor="@color/text_light"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefreshLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Refresh Location"
            android:backgroundTint="@color/gold"
            android:textColor="@color/bg_dark" />

        <!-- ───── Settings Section ───── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:background="@color/text_dim" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ALARM SETTINGS"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg">

            <!-- Volume row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔊"
                    android:textSize="18sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Volume"
                    android:textColor="@color/text_light"
                    android:textSize="15sp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderVolume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="0"
                    android:valueTo="100"
                    android:stepSize="5"
                    android:value="80"
                    app:thumbColor="@color/gold"
                    app:trackColorActive="@color/gold"
                    app:trackColorInactive="@color/text_dim" />

                <TextView
                    android:id="@+id/tvVolumePercent"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="80%"
                    android:textColor="@color/gold"
                    android:textSize="13sp"
                    android:gravity="end"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Vibration row -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchVibrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Vibrate"
                android:textColor="@color/text_light"
                android:textSize="15sp" />

            <!-- Language row — toggle group fills full width so all 3 buttons fit in portrait -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Alarm language"
                android:textColor="@color/text_light"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangEn"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="English"
                    android:textSize="12sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:textColor="@color/text_light" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangBoth"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="Both"
                    android:textSize="12sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:textColor="@color/text_light" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangHe"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="עברית"
                    android:textSize="12sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:textColor="@color/text_light" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>

        <!-- ───── Suggestions Section ───── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:background="@color/text_dim" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FEEDBACK"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSuggest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="💡  Suggest a Feature or New App"
            android:textColor="@color/gold_light"
            android:textSize="14sp"
            app:strokeColor="@color/gold_light" />

        <!-- ───── Test Mode Section ───── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:background="@color/text_dim" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchTestMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Test Mode"
            android:textColor="@color/text_light"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/testControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="@drawable/card_bg_test"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Simulate any date's alarm"
                android:textColor="@color/gold_light"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvTestDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No date selected"
                android:textColor="@color/text_light"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3" />

            <TextView
                android:id="@+id/tvTestPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/gold"
                android:textSize="14sp"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Pick Date"
                    android:backgroundTint="@color/snooze_color"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFireNow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Fire Alarm Now"
                    android:backgroundTint="@color/stop_color"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:enabled="false" />

            </LinearLayout>
        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="Alarm fires at local sunset each evening\nduring the 49-day Omer period.\nSaturday night: 20 minutes after sunset.\nThe app runs silently in the background\nand stops automatically after Shavuot." />

    </LinearLayout>
</ScrollView>
