<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_alarm"
    android:padding="32dp">

    <!-- Star of David decorative header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✡"
        android:textSize="48sp"
        android:textColor="@color/gold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Time to Count the Omer"
        android:textSize="20sp"
        android:textColor="@color/gold_light"
        android:fontFamily="serif" />

    <!-- Day number label -->
    <TextView
        android:id="@+id/tvDayLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/gold"
        android:fontFamily="serif" />

    <!-- Hebrew text -->
    <TextView
        android:id="@+id/tvHebrew"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:padding="20dp"
        android:background="@drawable/card_bg"
        android:textSize="22sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:fontFamily="serif"
        android:lineSpacingMultiplier="1.5" />

    <!-- English text -->
    <TextView
        android:id="@+id/tvEnglish"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        android:background="@drawable/card_bg"
        android:textSize="16sp"
        android:textColor="@color/text_light"
        android:gravity="center"
        android:fontFamily="serif"
        android:lineSpacingMultiplier="1.3" />

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSnooze"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Snooze\n(20 min)"
            android:textSize="14sp"
            android:backgroundTint="@color/snooze_color"
            android:textColor="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Stop"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/stop_color"
            android:textColor="@color/white" />

    </LinearLayout>

</LinearLayout>
